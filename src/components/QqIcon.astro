---
interface Props {
  class?: string;
  size?: number;
}

const { class: className = '', size = 18 } = Astro.props;
---

<svg
  class:list={['qq-icon', className]}
  width={size}
  height={size}
  viewBox="0 0 48 48"
  aria-hidden="true"
>
  <image href="/assets/images/qq-icon.png" width="48" height="48" />
</svg>
