---
import BilibiliIcon from './BilibiliIcon.astro';
import QqIcon from './QqIcon.astro';
import { BILIBILI_URL } from '../data/site';
---

<footer class="site-footer">
  <div class="container footer-inner">
    <p class="footer-copy">© 2026 foxletters-hq</p>

    <div class="footer-actions">
      <button
        type="button"
        class="btn btn-outline footer-cta"
        data-community-open
      >
        <QqIcon size={18} />
        <span data-i18n="footer.joinCommunity">加入社群</span>
      </button>

      <a
        href={BILIBILI_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="footer-link footer-link-bilibili"
      >
        <BilibiliIcon size={18} />
        <span data-i18n="footer.bilibili">哔哩哔哩</span>
      </a>
    </div>
  </div>
</footer>
