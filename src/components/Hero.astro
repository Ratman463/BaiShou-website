---
import { REPO_URL } from '../data/site';
---

<section id="hero" class="hero section">
  <div class="container hero-grid">
    <div class="hero-copy">
      <p class="hero-eyebrow animate-in">BaiShou-Next</p>
      <h1 class="hero-title animate-in animate-in-delay-1">白守</h1>
      <p class="hero-tagline animate-in animate-in-delay-2">以纯白誓约，守护彼此一生</p>
      <p class="hero-desc animate-in animate-in-delay-3">
        白守是为对抗遗忘而构建的灵魂容器——在本地守护你的记忆，与 AI 伙伴共同书写、共同成长。
        数据留在你的设备上，记忆只属于你。
      </p>
      <div class="hero-actions animate-in animate-in-delay-4">
        <a
          href={REPO_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn-primary"
        >
          前往 GitHub
        </a>
        <a href="#features" class="btn btn-outline">
          了解功能
        </a>
      </div>
    </div>

    <div class="hero-visual animate-in animate-in-delay-2">
      <div class="app-icon-frame" aria-hidden="true">
        <img
          src="/assets/images/app-icon.png"
          alt="白守应用图标"
          class="app-icon-hero"
          width="320"
          height="320"
          loading="eager"
        />
      </div>
    </div>
  </div>
</section>
