---
const umamiUrl = import.meta.env.PUBLIC_UMAMI_URL?.replace(/\/$/, '');
const umamiWebsiteId = import.meta.env.PUBLIC_UMAMI_WEBSITE_ID;
const enabled = Boolean(umamiUrl && umamiWebsiteId);
---

{
  enabled && (
    <script defer src={`${umamiUrl}/script.js`} data-website-id={umamiWebsiteId} />
  )
}
