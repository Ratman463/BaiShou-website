---
import { FOUNDER, CONTRIBUTORS } from '../data/site';

interface Person {
  name: string;
  role: string;
  github: string;
  avatar: string;
}

const people: Person[] = [FOUNDER, ...CONTRIBUTORS];
---

<section id="team" class="section">
  <div class="container">
    <div class="reveal section-heading">
      <p class="section-eyebrow">Team</p>
      <h2>团队</h2>
      <p class="section-lead">
        白守由热爱记忆与陪伴的人共同构建。更多贡献者请见
        <a
          href="https://github.com/foxletters-hq/BaiShou-website/graphs/contributors"
          target="_blank"
          rel="noopener noreferrer"
        >
          GitHub Contributors
        </a>
        。
      </p>
    </div>

    <div class="team-grid reveal">
      {people.map((person) => (
        <a
          href={person.github}
          target="_blank"
          rel="noopener noreferrer"
          class="card team-card"
        >
          <img
            src={person.avatar}
            alt={`${person.name} 的头像`}
            class="team-avatar"
            width="88"
            height="88"
            loading="lazy"
          />
          <div class="team-info">
            <h3>{person.name}</h3>
            <p class="team-role">{person.role}</p>
            <p class="team-handle">@{person.github.split('/').pop()}</p>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
